<UserControl
    x:Class="VolumeTrayAppWPF.WPF.NumericSpinner"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="{StaticResource DwellBoxHeight}"
    FocusVisualStyle="{x:Null}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="{StaticResource SpinnerColumnWidth}"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource DwellBoxBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="PART_TextBox"
                         Grid.Column="0"
                         Style="{StaticResource DwellNumberBoxTextBoxStyle}"
                         PreviewTextInput="OnPreviewTextInput"
                         PreviewMouseWheel="OnPreviewMouseWheel"
                         PreviewKeyDown="OnPreviewKeyDown"
                         GotKeyboardFocus="OnTextBoxFocusChanged"
                         LostKeyboardFocus="OnTextBoxFocusChanged"
                         LostFocus="OnTextBoxLostFocus"/>
                <TextBlock Grid.Column="1"
                           x:Name="PART_Suffix"
                           Style="{StaticResource DwellNumberBoxSuffixStyle}"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Button x:Name="PART_SpinUp"
                    Grid.Row="0"
                    Style="{StaticResource SpinnerButtonStyle}"
                    Click="OnSpinUpClick"
                    Content="&#xE70E;"/>
            <Button x:Name="PART_SpinDown"
                    Grid.Row="1"
                    Style="{StaticResource SpinnerButtonStyle}"
                    Click="OnSpinDownClick"
                    Content="&#xE70D;"/>
        </Grid>
    </Grid>
</UserControl>
