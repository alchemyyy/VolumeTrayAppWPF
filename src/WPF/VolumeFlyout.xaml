<Window
    x:Class="VolumeTrayAppWPF.WPF.VolumeFlyout"
    x:ClassModifier="internal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:audio="clr-namespace:VolumeTrayAppWPF.Audio"
    xmlns:wpf="clr-namespace:VolumeTrayAppWPF.WPF"
    xmlns:utils="clr-namespace:VolumeTrayAppWPF.WPF.Utils"
    xmlns:visuals="clr-namespace:VolumeTrayAppWPF.Visuals"
    xmlns:interop="clr-namespace:VolumeTrayAppWPF.Audio.Interop"
    xmlns:models="clr-namespace:VolumeTrayAppWPF.Models"
    xmlns:loc="clr-namespace:VolumeTrayAppWPF.Localization"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Width="350"
    SizeToContent="Height"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    Title="Volume">

    <Window.Resources>
        <!-- App-scope DynamicResource brushes still resolve here; per-flyout converters and slider style live local.
             BoolToVisibility comes from App.xaml (merged via Application.Resources). -->
        <wpf:ScalarToPercentConverter x:Key="ScalarToPercent"/>
        <wpf:VolumeGlyphConverter x:Key="VolumeGlyph"/>
        <wpf:DeviceIconGlyphConverter x:Key="DeviceIconGlyph"/>
        <wpf:DeviceIconOpacityConverter x:Key="DeviceIconOpacity"/>
        <wpf:TitleRowVerticalOffsetConverter x:Key="TitleRowVerticalOffset"/>
        <utils:DeviceButtonVisibilityConverter x:Key="DeviceButtonVisibility"/>

        <!-- Per-cell slot size for the icon grid drawer. Lifted into the resource dictionary as a
             DynamicResource source so XAML Hot Reload edits to this value propagate to every live
             CenteringWrapPanel instance instead of being trapped inside the already-instantiated
             ItemsPanelTemplate output. -->
        <sys:Double x:Key="GridSlotSize">36</sys:Double>

        <!-- Single source of truth for app-icon pixel sizes across both drawer modes. Slider rows
             bind their Image Width / Height to AppIconImageSize and their fallback / mute glyph
             FontSize to AppIconGlyphSize via DynamicResource. Grid rows go through VolumeFlyout's
             AppDrawerIconImageSize / AppDrawerIconGlyphSize properties (defined in code-behind),
             which read these same resources and then scale them by AppDrawerIconScalePercent.
             Tweak here once to retune every app icon in the flyout. -->
        <sys:Double x:Key="AppIconImageSize">22</sys:Double>
        <sys:Double x:Key="AppIconGlyphSize">20</sys:Double>

        <!-- Slider primitives. Lifted from BrightnessFlyout but stripped of curve / preview chrome -
             the volume slider only shows a track, fill, and thumb. -->
        <Style x:Key="VolumeSliderThumbStyle" TargetType="Thumb">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid>
                            <TextBlock Text="{DynamicResource SliderThumbGlyph}"
                                       FontFamily="{DynamicResource SliderThumbGlyphFont}"
                                       FontSize="{DynamicResource SliderThumbGlyphSize}"
                                       Width="{DynamicResource SliderThumbGlyphWidth}"
                                       Height="{DynamicResource SliderThumbGlyphHeight}"
                                       Foreground="{DynamicResource ThemeSliderThumb}"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Visibility="{DynamicResource SliderThumbGlyphVisibility}">
                                <TextBlock.LayoutTransform>
                                    <ScaleTransform ScaleX="{DynamicResource SliderThumbGlyphScaleX}" ScaleY="1"/>
                                </TextBlock.LayoutTransform>
                            </TextBlock>
                            <Border Width="{DynamicResource SliderThumbGlyphWidth}"
                                    Height="{DynamicResource SliderThumbGlyphHeight}"
                                    CornerRadius="{DynamicResource CornerRadiusCapsule}"
                                    Background="{DynamicResource ThemeSliderThumb}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{DynamicResource SliderThumbCapsuleVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filled track-fill (left of thumb): ThemeSliderProgress, horizontal 4-DIP bar.
             BasedOn SliderTrackRepeatButtonStyle for common setters; overrides only Background + template. -->
        <Style x:Key="VolumeSliderDecreaseButtonStyle" TargetType="RepeatButton" BasedOn="{StaticResource SliderTrackRepeatButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource ThemeSliderProgress}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" Height="4"
                                CornerRadius="{DynamicResource CornerRadiusSmall}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Empty track-fill (right of thumb): transparent, horizontal 4-DIP bar. Same chassis as
             the decrease half; only Background differs. -->
        <Style x:Key="VolumeSliderIncreaseButtonStyle" TargetType="RepeatButton" BasedOn="{StaticResource SliderTrackRepeatButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" Height="4"
                                CornerRadius="{DynamicResource CornerRadiusSmall}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VolumeSliderStyle" TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <!-- Float-fidelity tuning (matches BrightnessFlyout):
                 IsSnapToTickEnabled / IsMoveToPointEnabled both off so the slider value isn't
                 rounded to LargeChange increments on click. SliderClickDragBehavior wires
                 point-to-jump-and-drag so a click on the track captures and the thumb keeps
                 following the cursor through the drag. -->
            <Setter Property="IsSnapToTickEnabled" Value="False"/>
            <Setter Property="IsMoveToPointEnabled" Value="False"/>
            <Setter Property="SmallChange" Value="0.1"/>
            <Setter Property="LargeChange" Value="0.1"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="utils:KeyboardFocusBehavior.ShowKeyboardFocus" Value="True"/>
            <Setter Property="utils:SliderClickDragBehavior.Enable" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <!-- Transparent hit-test surface for slider wheel + click. Height +
                                 symmetric negative margins extend the wheel hit area 5 DIPs above
                                 and below the slider's visible track so a wheel event landing in
                                 the 10-DIP gap between two app sliders still adjusts the slider
                                 instead of bubbling to the cell-list ScrollViewer, and so the slider
                                 is generally easier to hover-scroll. Net layout contribution
                                 (34 - 5 - 5 = 24) keeps the slider's allocated height unchanged. -->
                            <Rectangle Fill="Transparent" Height="34" Margin="0,-5,0,-5"/>
                            <Border Height="4"
                                    Background="{DynamicResource ThemeSliderTrack}"
                                    CornerRadius="{DynamicResource CornerRadiusSmall}"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False"/>
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource VolumeSliderDecreaseButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource VolumeSliderThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource VolumeSliderIncreaseButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                            <!-- Two-layer peak meter overlay. MeterPeak (base) is sized to min(L, R) and
                                 MeterPeakStereo paints on top sized to max(L, R). -->
                            <Border x:Name="MeterPeakStereo"
                                    Height="4"
                                    Width="0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource MeterPeakStereoBrush}"
                                    CornerRadius="{DynamicResource CornerRadiusSmall}"
                                    IsHitTestVisible="False"/>
                            <Border x:Name="MeterPeak"
                                    Height="4"
                                    Width="0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource MeterPeakBrush}"
                                    CornerRadius="{DynamicResource CornerRadiusSmall}"
                                    IsHitTestVisible="False"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Device-row icon button (mute, lock, equalizer APO, listen, device-icon).
             BasedOn TransparentRoundedButtonBase for common setters; template is overridden to swap
             ThemeHover / ThemePressed for the stronger-contrast ThemeButtonHover / ThemeButtonPressed
             so the hover pill reads against the ThemeFooterBackground card the flyout cells sit on. -->
        <Style x:Key="DeviceIconButtonStyle" TargetType="Button" BasedOn="{StaticResource TransparentRoundedButtonBase}">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{DynamicResource CornerRadiusMedium}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ThemeButtonPressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Header (title-bar) icon button: settings, sound-settings, undock.
             Different hover from DeviceIconButton: just the standard ThemePressed (no separate press
             state), painted via Style.Triggers on Background. The template strips the base's
             ControlTemplate.Triggers because Background flows in through TemplateBinding. -->
        <Style x:Key="HeaderIconButtonStyle" TargetType="Button" BasedOn="{StaticResource TransparentRoundedButtonBase}">
            <Setter Property="Width" Value="40"/>
      <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,-3,0,1"/>
      <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                      <Border Background="{TemplateBinding Background}"
                              CornerRadius="{DynamicResource CornerRadiusMedium}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemePressed}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ContextMenu resource: per-endpoint default-format picker. Opened from the device-name /
             format-readout right-click handler. ItemsSource is set imperatively at open time
             (PlacementTarget.Tag holds the DeviceFormatMenuContext payload) so each open builds
             from the live endpoint state without rebinding any ItemsControl. -->
        <ContextMenu x:Key="DefaultFormatContextMenu"
                     Placement="Bottom"
                     ItemsSource="{Binding Tag.Items, RelativeSource={RelativeSource Self}}">
            <ContextMenu.ItemContainerStyle>
                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                    <Setter Property="Header" Value="{Binding Label}"/>
                    <Setter Property="Command" Value="{Binding Command}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                            <Setter Property="HeaderTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{x:Static visuals:GlyphCatalog.CIRCLE}"
                                                       FontFamily="{StaticResource IconFontFamily}"
                                                       FontSize="8"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContextMenu.ItemContainerStyle>
        </ContextMenu>

        <!-- ContextMenu resource: per-endpoint listen-target picker (capture endpoints only). Items
             are flat: the first row is "Default Playback Device" (null target), the rest are active
             render endpoints; a separator slot is rendered by toggling HeaderTemplate. The simpler
             render is one row per entry; the current selection ticks via IsChecked. -->
        <ContextMenu x:Key="ListenTargetContextMenu"
                     Placement="Bottom"
                     ItemsSource="{Binding Tag.Items, RelativeSource={RelativeSource Self}}">
            <ContextMenu.ItemContainerStyle>
                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                    <Setter Property="Header" Value="{Binding Label}"/>
                    <Setter Property="IsCheckable" Value="True"/>
                    <Setter Property="IsChecked" Value="{Binding IsCurrent, Mode=OneWay}"/>
                    <Setter Property="Command" Value="{Binding Command}"/>
                </Style>
            </ContextMenu.ItemContainerStyle>
        </ContextMenu>

        <!-- Per-app session row. Reused by both AppsAbove and AppsBelow cell templates so the row
             chrome (icon, slider, percent, mute hover) is described once. DataContext is an
             AudioAppGroup. The mute-dim trigger reaches the cell's Device.IsMuted by walking up two
             ContentPresenters: the inner one wraps this AudioAppGroup item, and the outer wraps the
             cell. Going up two ContentPresenter levels lands us at the outer ContentPresenter whose
             DataContext is the VolumeFlyoutCell. -->
        <DataTemplate x:Key="SessionRowTemplate" DataType="{x:Type audio:AudioAppGroup}">
            <Grid Margin="0,0,0,8">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Opacity" Value="1.0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                <Setter Property="Opacity" Value="0.4"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DataContext.Device.IsMuted, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                <Setter Property="Opacity" Value="0.4"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DataContext.Device.IsActive, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </DataTrigger>
                            <!-- DimInactive mode: on a capture device, dim app sessions that aren't
                                 currently consuming the mic. Active sessions stay at full opacity. -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding CaptureActivityIndicator, RelativeSource={RelativeSource AncestorType=Window}}" Value="{x:Static models:CaptureActivityIndicator.DimInactive}"/>
                                    <Condition Binding="{Binding DataContext.Device.IsCaptureDevice, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True"/>
                                    <Condition Binding="{Binding State}" Value="{x:Static interop:AudioSessionState.Inactive}"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Opacity" Value="0.4"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding CaptureActivityIndicator, RelativeSource={RelativeSource AncestorType=Window}}" Value="{x:Static models:CaptureActivityIndicator.DimInactive}"/>
                                    <Condition Binding="{Binding DataContext.Device.IsCaptureDevice, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True"/>
                                    <Condition Binding="{Binding State}" Value="{x:Static interop:AudioSessionState.Expired}"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Opacity" Value="0.4"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App icon. Falls back to a generic glyph when the icon resolver returns null;
                     hover overlays the muted-speaker glyph so click=mute reads visually.
                     Width / Height / FontSize pull from the AppIconImageSize / AppIconGlyphSize
                     resources so the slider-mode icon size tracks the same root truth the grid
                     mode multiplies by its scale percent. Tag carries the AudioAppGroup so the
                     click handler can read it without a visual-tree walk. -->
                <Grid x:Name="AppIconRoot" Grid.Column="0"
                      Width="{DynamicResource AppIconImageSize}"
                      Height="{DynamicResource AppIconImageSize}"
                      Margin="0,0,10,0" VerticalAlignment="Center"
                      Background="Transparent"
                      Tag="{Binding}"
                      ToolTip="{Binding TooltipText}"
                      ToolTipService.InitialShowDelay="1000"
                      PreviewMouseLeftButtonUp="AppIcon_PreviewMouseLeftButtonUp">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <!-- Capture sessions are not click-to-mute, so drop the hand cursor too. -->
                                <DataTrigger Binding="{Binding DataContext.Device.IsCaptureDevice, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                    <Setter Property="Cursor" Value="Arrow"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Image Source="{Binding Icon}"
                           Width="{DynamicResource AppIconImageSize}"
                           Height="{DynamicResource AppIconImageSize}"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <!-- Placeholder app icon, shown until AppIconResolver produces a real one. -->
                    <TextBlock Text="{x:Static visuals:GlyphCatalog.APP_FALLBACK}"
                               FontFamily="{StaticResource IconFontFamily}"
                               FontSize="{DynamicResource AppIconGlyphSize}"
                               Foreground="{DynamicResource ThemeIconForeground}"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- Mute-X hover overlay. Mirrors GlyphCatalog.APP_MUTE_OVERLAY. -->
                    <TextBlock IsHitTestVisible="False"
                               Text="{x:Static visuals:GlyphCatalog.APP_MUTE_OVERLAY}"
                               FontFamily="{StaticResource IconFontFamily}"
                               FontSize="{DynamicResource AppIconGlyphSize}"
                               Foreground="{DynamicResource ThemeIconForeground}"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Opacity" Value="0.5"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=AppIconRoot}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <!-- Capture sessions have no useful per-app mute, so suppress the X overlay entirely. -->
                                    <DataTrigger Binding="{Binding DataContext.Device.IsCaptureDevice, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- Mini glyph overlay slot. Empty by default; on a capture-device drawer, shows
                         GlyphCatalog.CIRCLE for any app whose AudioAppGroup.State is Active (i.e. the
                         app currently has the microphone stream open). Cell ancestor walk matches the
                         existing Device.IsMuted trigger pattern. The exclusive-control-holder lock
                         overlay takes precedence (last DataTrigger wins): when this app's group is
                         holding the parent device in exclusive mode, swap the mic-activity dot for
                         a LOCK glyph so the gesture reads "this is the app holding the device". -->
                    <Grid Width="12" Height="12"
                          HorizontalAlignment="Left" VerticalAlignment="Bottom"
                          Margin="11,0,0,-2"
                          IsHitTestVisible="False">
                        <TextBlock FontFamily="{StaticResource IconFontFamily}"
                                   FontWeight="ExtraBold"
                                   Foreground="{DynamicResource ThemeIconForeground}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value=""/>
                                    <Setter Property="FontSize" Value="6"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding CaptureActivityIndicator, RelativeSource={RelativeSource AncestorType=Window}}" Value="{x:Static models:CaptureActivityIndicator.ActiveGlyph}"/>
                                                <Condition Binding="{Binding DataContext.Device.IsCaptureDevice, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True"/>
                                                <Condition Binding="{Binding State}" Value="{x:Static interop:AudioSessionState.Active}"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Text" Value="{x:Static visuals:GlyphCatalog.CIRCLE}"/>
                                        </MultiDataTrigger>
                                        <!-- Lock overrides the mic-activity dot when present. Needs a
                                             larger font size than the dot to read clearly at the same anchor. -->
                                        <DataTrigger Binding="{Binding IsExclusiveControlHolder}" Value="True">
                                            <Setter Property="Text" Value="{x:Static visuals:GlyphCatalog.LOCK}"/>
                                            <Setter Property="FontSize" Value="9"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>

                <wpf:VolumeSlider Grid.Column="1"
                                  Style="{StaticResource VolumeSliderStyle}"
                                  Value="{Binding Volume, Mode=TwoWay, Converter={StaticResource ScalarToPercent}, UpdateSourceTrigger=PropertyChanged}"
                                  PeakValueMin="{Binding PeakValueMin}"
                                  PeakValueMax="{Binding PeakValueMax}"
                                  ToolTip="{Binding DisplayName}"
                                  PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                                  PreviewMouseWheel="Slider_PreviewMouseWheel"/>

                <TextBlock Grid.Column="2"
                           Text="{Binding Volume, Converter={StaticResource ScalarToPercent}, StringFormat={}{0:0}}"
                           FontSize="18"
                           Foreground="{DynamicResource ThemeForeground}"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           MinWidth="32"
                           TextAlignment="Right"/>
            </Grid>
        </DataTemplate>

        <!-- Device row content. Used by both cell templates - one Grid expressed once with the
             cell's Device set as DataContext on the wrapper. Slider events route to the same
             Slider_* handlers as session rows; the handlers branch on DataContext type to tell a
             device slider from an app slider. -->
        <ControlTemplate x:Key="DeviceRowTemplate" TargetType="ContentControl">
            <Grid DataContext="{Binding Device}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title + control buttons row. Grouped in one Grid so the whole header
                     band (name text + all per-device action buttons) moves as a unit.
                     Grid.Row binds to the window's DeviceTitleRowIndex, which flips between row 1
                     (below slider, default) and row 0 (above slider) per FlyoutDeviceTitlePosition.
                     The slider grid below binds to DeviceSliderRowIndex so the two always occupy
                     distinct rows.
                     Column layout left to right:
                       0  device name (takes remaining width)
                       1  exclusive-mode toggle (lock / unlock)
                       2  Equalizer APO state / install
                       3  Listen-to-this-device (capture endpoints only; collapses to zero on render)
                       4  device icon (set as default / enable-disable hub). -->
                <Grid Grid.Row="{Binding DeviceTitleRowIndex, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                      Margin="-1,-4,0,6">
                    <!-- AboveSlider: TranslateTransform anchors the title's visual bottom to the
                         percent textblock's top (the volume-level indicator) via element-name
                         bindings to DeviceSliderRow and DeviceVolumePercent. BelowSlider: converter
                         returns 0 so the title stays put. RenderTransform doesn't participate in
                         measure, so the slider row doesn't shift along with the title. -->
                    <Grid.RenderTransform>
                        <TranslateTransform>
                            <TranslateTransform.Y>
                                <MultiBinding Converter="{StaticResource TitleRowVerticalOffset}">
                                    <Binding Path="DeviceTitleRowIndex"
                                             RelativeSource="{RelativeSource AncestorType={x:Type Window}}"/>
                                    <Binding Path="ActualHeight" ElementName="DeviceSliderRow"/>
                                    <Binding Path="ActualHeight" ElementName="DeviceVolumePercent"/>
                                </MultiBinding>
                            </TranslateTransform.Y>
                        </TranslateTransform>
                    </Grid.RenderTransform>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Device name. TextBlock for view mode; double-click swaps to the sibling
                         TextBox for inline rename. Empty / whitespace on commit clears the
                         PKEY_Device_FriendlyName override and the OS-synthesized name returns.
                         RenderTransform nudges the whole inner column down 2 px when the format
                         readout is hidden, so the name sits at the row's optical center instead
                         of riding high where the format strip would have sat. The Canvas is
                         Collapsed in that same state, so the format-text doesn't visibly shift. -->
                    <Grid Grid.Column="0">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowDeviceFormatText, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="False">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform Y="2"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <TextBlock x:Name="DeviceNameText"
                                   Text="{Binding FriendlyName, FallbackValue='No audio device'}"
                                   Tag="{Binding}"
                                   Foreground="{DynamicResource ThemeForeground}"
                                   Background="Transparent"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MouseLeftButtonDown="DeviceNameText_MouseLeftButtonDown"
                                   PreviewMouseRightButtonUp="DeviceFormatMenu_PreviewMouseRightButtonUp"/>
                        <TextBox x:Name="DeviceNameEdit"
                                 Visibility="Collapsed"
                                 FontSize="14"
                                 VerticalAlignment="Center"
                                 Background="Transparent"
                                 Foreground="{DynamicResource ThemeForeground}"
                                 CaretBrush="{DynamicResource ThemeForeground}"
                                 BorderThickness="0"
                                 Padding="0"
                                 Margin="0"
                                 KeyDown="DeviceNameEdit_KeyDown"
                                 LostKeyboardFocus="DeviceNameEdit_LostKeyboardFocus"/>
                        <!-- Compact PKEY_AudioEngine_DeviceFormat readout, drawn just below the
                             name baseline. Hosted in a Canvas so its size doesn't feed back into
                             the row's measure - the title row stays sized by the icon buttons and
                             the format text overflows downward into the band below. The TextBlock's
                             transparent background widens the hit area to the whole bounding box
                             so the right-click format picker is reachable on glyph gaps too. -->
                        <Canvas ClipToBounds="False"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Visibility="{Binding ShowDeviceFormatText, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock x:Name="DeviceFormatText"
                                       Text="{Binding DefaultFormat}"
                                       Tag="{Binding}"
                                       Canvas.Top="9"
                                       FontSize="8"
                                       Foreground="{DynamicResource ThemeForeground}"
                                       Background="Transparent"
                                       Opacity="0.45"
                                       PreviewMouseRightButtonUp="DeviceFormatMenu_PreviewMouseRightButtonUp"/>
                        </Canvas>
                    </Grid>
                    <!-- Exclusive-mode toggle. Three visual states driven by two bindings:
                           IsExclusiveModeAllowed=False  -> Unlock glyph, dimmed (mmsys.cpl checkbox off)
                           IsExclusiveModeAllowed=True,  IsExclusiveControlHeld=False -> Unlock, full bright
                           IsExclusiveModeAllowed=True,  IsExclusiveControlHeld=True  -> Lock,   full bright
                         Click toggles the allow bit on the endpoint. Held / not-held is observed
                         from the audio engine, not user-toggleable from this button. -->
                    <Button x:Name="ExclusiveModeButton" Grid.Column="1"
                            Margin="0,3,0,-3"
                            Tag="{Binding}"
                            Click="ExclusiveModeButton_Click">
                        <Button.Visibility>
                            <MultiBinding Converter="{StaticResource DeviceButtonVisibility}">
                                <Binding Path="IsCaptureDevice"/>
                                <Binding Path="ShowLockButtonForPlayback" RelativeSource="{RelativeSource AncestorType={x:Type Window}}"/>
                                <Binding Path="ShowLockButtonForRecording" RelativeSource="{RelativeSource AncestorType={x:Type Window}}"/>
                            </MultiBinding>
                        </Button.Visibility>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DeviceIconButtonStyle}">
                                <Setter Property="Opacity" Value="1.0"/>
                                <Setter Property="ToolTip" Value="{loc:Loc Flyout_ExclusiveMode_Tooltip_Allowed}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExclusiveControlHeld}" Value="True">
                                        <Setter Property="ToolTip" Value="{loc:Loc Flyout_ExclusiveMode_Tooltip_Held}"/>
                                    </DataTrigger>
                                    <!-- Disallowed wins last so the dim + disallowed-tooltip always paint
                                         when the checkbox is off, regardless of held state. -->
                                    <DataTrigger Binding="{Binding IsExclusiveModeAllowed}" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                        <Setter Property="ToolTip" Value="{loc:Loc Flyout_ExclusiveMode_Tooltip_Disallowed}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="15"
                                   Foreground="{DynamicResource ThemeIconForeground}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{x:Static visuals:GlyphCatalog.UNLOCK}"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsExclusiveModeAllowed}" Value="True"/>
                                                <Condition Binding="{Binding IsExclusiveControlHeld}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Text" Value="{x:Static visuals:GlyphCatalog.LOCK}"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>

                    <!-- Equalizer APO state. EQUALIZER glyph dim / bright tracks whether the chain is
                         actually running on this endpoint; the SIGNAL_NOT_CONNECTED overlay rides on top
                         (full bright) when the APO binary can't be found anywhere on the system. Click
                         is a two-state toggle (Running -> uninstall; everything else -> install + enable);
                         NotAvailable click routes through the not-available dialog in code-behind. -->
                    <Button x:Name="EqualizerAPOButton" Grid.Column="2"
                            Margin="0,3,0,-3"
                            Tag="{Binding}"
                            Click="EqualizerAPOButton_Click"
                            PreviewMouseRightButtonUp="EqualizerAPOButton_PreviewMouseRightButtonUp">
                        <Button.Visibility>
                            <MultiBinding Converter="{StaticResource DeviceButtonVisibility}">
                                <Binding Path="IsCaptureDevice"/>
                                <Binding Path="ShowEqualizerAPOButtonForPlayback" RelativeSource="{RelativeSource AncestorType={x:Type Window}}"/>
                                <Binding Path="ShowEqualizerAPOButtonForRecording" RelativeSource="{RelativeSource AncestorType={x:Type Window}}"/>
                            </MultiBinding>
                        </Button.Visibility>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DeviceIconButtonStyle}">
                                <Setter Property="ToolTip" Value="{loc:Loc Flyout_EqualizerAPO_Tooltip_NotAvailable}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EqualizerAPOState}"
                                                 Value="{x:Static audio:EqualizerAPOState.Running}">
                                        <Setter Property="ToolTip" Value="{loc:Loc Flyout_EqualizerAPO_Tooltip_Running}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding EqualizerAPOState}"
                                                 Value="{x:Static audio:EqualizerAPOState.EnhancementsOff}">
                                        <Setter Property="ToolTip" Value="{loc:Loc Flyout_EqualizerAPO_Tooltip_EnhancementsOff}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding EqualizerAPOState}"
                                                 Value="{x:Static audio:EqualizerAPOState.NotInstalled}">
                                        <Setter Property="ToolTip" Value="{loc:Loc Flyout_EqualizerAPO_Tooltip_NotInstalled}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <!-- Main glyph. Opacity binds via the per-state trigger below: only Running
                                 reads full bright; every other state dims so the button visually says
                                 "not in effect right now". -->
                            <TextBlock x:Name="EqualizerAPOGlyph"
                                       Text="{x:Static visuals:GlyphCatalog.EQUALIZER}"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="15"
                                       Foreground="{DynamicResource ThemeIconForeground}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Opacity" Value="0.4"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EqualizerAPOState}"
                                                         Value="{x:Static audio:EqualizerAPOState.Running}">
                                                <Setter Property="Opacity" Value="1.0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- "APO not detected on this system" mini-glyph overlay. Anchored bottom-right
                                 so it reads as a badge on the equalizer glyph. Stays full bright while the
                                 base glyph dims; only visible in the NotAvailable state. -->
                            <TextBlock x:Name="EqualizerAPOMissingOverlay"
                                       Text="{x:Static visuals:GlyphCatalog.SIGNAL_NOT_CONNECTED}"
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="11"
                                       FontWeight="ExtraBold"
                                       Foreground="{DynamicResource ThemeIconForeground}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom"
                                       Margin="0,0,-2,-1"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EqualizerAPOState}"
                                                         Value="{x:Static audio:EqualizerAPOState.NotAvailable}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>

                    <!-- Listen-to-this-device button. Capture endpoints only - collapsed on
                         playback rows so the slot stays empty and the icon button hugs the right.
                         Left click toggles the listen-enable bit (pid 1) and leaves the existing
                         target untouched; ctrl+left toggles on with target reset to "follow default
                         playback device" (pid 0 deleted). Right click opens a context menu to pick
                         a specific target. Opacity binds to (listening AND target active) so the
                         button reads dim whenever no audio is actually flowing. -->
                    <Button x:Name="ListenButton" Grid.Column="3"
                            Margin="0,3,0,-3"
                            Tag="{Binding}"
                            Click="ListenButton_Click"
                            PreviewMouseRightButtonUp="ListenButton_PreviewMouseRightButtonUp"
                            ToolTip="{loc:Loc Flyout_ListenButton_Tooltip}">
                        <!-- Visibility = capture endpoint AND the global toggle is on. Collapsed
                             leaves the column zero-width so playback rows look unchanged and the
                             icon button hugs the right edge as before. -->
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DeviceIconButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsCaptureDevice}" Value="True"/>
                                            <Condition Binding="{Binding ShowListenButtonForRecording, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="{x:Static visuals:GlyphCatalog.EAR_LISTEN}"
                                   Opacity="{Binding IsListenButtonActive, Converter={StaticResource DeviceIconOpacity}}"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="15"
                                   Foreground="{DynamicResource ThemeIconForeground}"/>
                    </Button>
                    <Button Grid.Column="4"
                            Style="{StaticResource DeviceIconButtonStyle}"
                            Margin="0,3,-1,-3"
                            Tag="{Binding}"
                            Click="DeviceIcon_Click"
                            PreviewMouseRightButtonUp="DeviceIcon_PreviewMouseRightButtonUp"
                            ToolTip="{loc:Loc Flyout_DeviceIcon_Tooltip}">
                        <Button.Visibility>
                            <MultiBinding Converter="{StaticResource DeviceButtonVisibility}">
                                <Binding Path="IsCaptureDevice"/>
                                <Binding Path="ShowDefaultDeviceButtonForPlayback" RelativeSource="{RelativeSource AncestorType={x:Type Window}}"/>
                                <Binding Path="ShowDefaultDeviceButtonForRecording" RelativeSource="{RelativeSource AncestorType={x:Type Window}}"/>
                            </MultiBinding>
                        </Button.Visibility>
                        <TextBlock Opacity="{Binding IsActive, Converter={StaticResource DeviceIconOpacity}}"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   Foreground="{DynamicResource ThemeIconForeground}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="18"/>
                                    <Style.Triggers>
                                        <!-- Disabled glyph reads small at the shared base size; translate recenters its ink in the 28x28 button -->
                                        <Trigger Property="Text" Value="{x:Static visuals:GlyphCatalog.PLAYBACK_DEVICE_DISABLED}">
                                            <Setter Property="FontSize" Value="34"/>
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TranslateTransform X="-2" Y="-4"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource DeviceIconGlyph}">
                                    <Binding Path="IsActive"/>
                                    <Binding Path="IsDefault"/>
                                    <Binding Path="IsDefaultCommunications"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Button>
                </Grid>

                <Grid x:Name="DeviceSliderRow"
                      Grid.Row="{Binding DeviceSliderRowIndex, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="DeviceMuteButton" Grid.Column="0"
                            Tag="{Binding}"
                            Click="DeviceMute_Click"
                            ToolTip="Mute"
                            Width="33" Height="32"
                            Margin="-8,-12,4,-12">
                        <!-- BasedOn the shared icon-button style, plus mute / disabled dim triggers
                             that match the slider / percent-text dim so the whole row reads as
                             "muted" or "disabled" together. -->
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DeviceIconButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <!-- Wrapping Grid pins the content slot to 32x32 so the button's hit area stays
                                 constant regardless of which glyph is shown. The inner TextBlock auto-sizes
                                 to its glyph; HorizontalAlignment on it positions the glyph-sized box within
                                 the 32x32 slot, so a Right alignment hugs the slot's right edge no matter how
                                 close the glyph's natural width is to 32. -->
                        <Grid Width="32" Height="32">
                            <TextBlock FontFamily="{StaticResource IconFontFamily}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeIconForeground}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <!-- Single shared FontSize / weight / offset applied to every mic glyph,
                                             and a shared HorizontalAlignment for every playback (speaker tier)
                                             glyph. Tune any value here and every matching trigger picks it up. -->
                                        <Style.Resources>
                                            <sys:Double x:Key="MicGlyphFontSize">20.5</sys:Double>
                                            <FontWeight x:Key="MicGlyphFontWeight">ExtraBold</FontWeight>
                                            <TranslateTransform x:Key="MicGlyphOffset" X="-1" Y="0"/>
                                            <HorizontalAlignment x:Key="PlaybackGlyphAlignment">Right</HorizontalAlignment>
                                            <TranslateTransform x:Key="PlaybackGlyphOffset" X="0" Y="0"/>
                                        </Style.Resources>
                                        <!-- FontSize and HorizontalAlignment live in the style (not as local
                                             values on the TextBlock) so the per-glyph triggers below can override
                                             them. Local values beat style triggers in WPF DP precedence. -->
                                        <Setter Property="FontSize" Value="26"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Text">
                                            <Setter.Value>
                                                <MultiBinding Converter="{StaticResource VolumeGlyph}">
                                                    <Binding Path="Volume"/>
                                                    <Binding Path="IsMuted"/>
                                                    <Binding Path="IsCaptureDevice"/>
                                                    <Binding Path="IsListeningToThisDevice"/>
                                                    <Binding Path="IsCaptureSleeping"/>
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <!-- Mic glyphs fill more of their em-box than the speaker tier glyphs,
                                                 so they read fatter at the shared base size. Drop FontSize so the
                                                 ink weight matches the volume tiers visually, and apply the shared
                                                 MicGlyphOffset to compensate for Segoe Fluent's non-symmetric baseline. -->
                                            <Trigger Property="Text" Value="{x:Static visuals:GlyphCatalog.MICROPHONE}">
                                                <Setter Property="FontSize" Value="{StaticResource MicGlyphFontSize}"/>
                                                <Setter Property="FontWeight" Value="{StaticResource MicGlyphFontWeight}"/>
                                                <Setter Property="RenderTransform" Value="{StaticResource MicGlyphOffset}"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="{x:Static visuals:GlyphCatalog.MICROPHONE_OFF}">
                                                <Setter Property="FontSize" Value="{StaticResource MicGlyphFontSize}"/>
                                                <Setter Property="FontWeight" Value="{StaticResource MicGlyphFontWeight}"/>
                                                <Setter Property="RenderTransform" Value="{StaticResource MicGlyphOffset}"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="{x:Static visuals:GlyphCatalog.MICROPHONE_LISTENING}">
                                                <Setter Property="FontSize" Value="{StaticResource MicGlyphFontSize}"/>
                                                <Setter Property="FontWeight" Value="{StaticResource MicGlyphFontWeight}"/>
                                                <Setter Property="RenderTransform" Value="{StaticResource MicGlyphOffset}"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="{x:Static visuals:GlyphCatalog.MICROPHONE_SLEEP}">
                                                <Setter Property="FontSize" Value="{StaticResource MicGlyphFontSize}"/>
                                                <Setter Property="FontWeight" Value="{StaticResource MicGlyphFontWeight}"/>
                                                <Setter Property="RenderTransform" Value="{StaticResource MicGlyphOffset}"/>
                                            </Trigger>
                                            <!-- Speaker tier glyphs share the PlaybackGlyphAlignment HorizontalAlignment
                                                 so the glyph-sized TextBlock anchors to one edge of the 32x32 slot
                                                 regardless of how close the natural glyph width is to the slot, and
                                                 share PlaybackGlyphOffset to nudge the ink off the anchored edge.
                                                 The mute hover preview lands on PLAYBACK_VOLUME_MUTE too, so it picks
                                                 this up automatically. -->
                                            <Trigger Property="Text" Value="{x:Static visuals:GlyphCatalog.PLAYBACK_VOLUME_MUTE}">
                                                <Setter Property="HorizontalAlignment" Value="{StaticResource PlaybackGlyphAlignment}"/>
                                                <Setter Property="RenderTransform" Value="{StaticResource PlaybackGlyphOffset}"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="{x:Static visuals:GlyphCatalog.PLAYBACK_VOLUME_SILENT}">
                                                <Setter Property="HorizontalAlignment" Value="{StaticResource PlaybackGlyphAlignment}"/>
                                                <Setter Property="RenderTransform" Value="{StaticResource PlaybackGlyphOffset}"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="{x:Static visuals:GlyphCatalog.PLAYBACK_VOLUME_LOW}">
                                                <Setter Property="HorizontalAlignment" Value="{StaticResource PlaybackGlyphAlignment}"/>
                                                <Setter Property="RenderTransform" Value="{StaticResource PlaybackGlyphOffset}"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="{x:Static visuals:GlyphCatalog.PLAYBACK_VOLUME_MID}">
                                                <Setter Property="HorizontalAlignment" Value="{StaticResource PlaybackGlyphAlignment}"/>
                                                <Setter Property="RenderTransform" Value="{StaticResource PlaybackGlyphOffset}"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="{x:Static visuals:GlyphCatalog.PLAYBACK_VOLUME_HIGH}">
                                                <Setter Property="HorizontalAlignment" Value="{StaticResource PlaybackGlyphAlignment}"/>
                                                <Setter Property="RenderTransform" Value="{StaticResource PlaybackGlyphOffset}"/>
                                            </Trigger>
                                            <!-- Hover preview = "click mutes". Render rows preview the speaker mute glyph;
                                                 capture rows preview MICROPHONE_OFF so the gesture reads correctly on a mic. -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsMouseOver, ElementName=DeviceMuteButton}" Value="True"/>
                                                    <Condition Binding="{Binding IsCaptureDevice}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Text" Value="{x:Static visuals:GlyphCatalog.PLAYBACK_VOLUME_MUTE}"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsMouseOver, ElementName=DeviceMuteButton}" Value="True"/>
                                                    <Condition Binding="{Binding IsCaptureDevice}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Text" Value="{x:Static visuals:GlyphCatalog.MICROPHONE_OFF}"/>
                                                <Setter Property="FontSize" Value="{StaticResource MicGlyphFontSize}"/>
                                                <Setter Property="FontWeight" Value="{StaticResource MicGlyphFontWeight}"/>
                                                <Setter Property="RenderTransform" Value="{StaticResource MicGlyphOffset}"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>

                    <wpf:VolumeSlider Grid.Column="1"
                                      Value="{Binding Volume, Mode=TwoWay, Converter={StaticResource ScalarToPercent}, UpdateSourceTrigger=PropertyChanged}"
                                      PeakValueMin="{Binding PeakValueMin}"
                                      PeakValueMax="{Binding PeakValueMax}"
                                      ToolTip="{Binding FriendlyName}"
                                      PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                                      PreviewMouseWheel="Slider_PreviewMouseWheel">
                        <wpf:VolumeSlider.Style>
                            <Style TargetType="{x:Type wpf:VolumeSlider}" BasedOn="{StaticResource VolumeSliderStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </wpf:VolumeSlider.Style>
                    </wpf:VolumeSlider>

                    <TextBlock x:Name="DeviceVolumePercent"
                               Grid.Column="2"
                               Text="{Binding Volume, Converter={StaticResource ScalarToPercent}, StringFormat={}{0:0}}"
                               FontSize="18"
                               Foreground="{DynamicResource ThemeForeground}"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               MinWidth="32"
                               TextAlignment="Right">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>
        </ControlTemplate>

        <!-- Per-app icon cell for the grid drawer. Sister of SessionRowTemplate but icon-only - no
             slider, no percent text. Click toggles mute via the same AppIcon_PreviewMouseLeftButtonUp
             handler the slider row uses. The cell is 36x36 with the icon centered at 22x22 so the hit
             target is comfortable while the icon itself matches the slider-row visual. The dim and
             capture-activity triggers mirror SessionRowTemplate's so a muted / inactive / dim-on-
             capture-inactive state reads the same in both drawer modes. -->
        <DataTemplate x:Key="GridIconTemplate" DataType="{x:Type audio:AudioAppGroup}">
            <Grid x:Name="AppIconRoot"
                  Width="36" Height="36"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  Background="Transparent"
                  Tag="{Binding}"
                  ToolTip="{Binding TooltipText}"
                  ToolTipService.InitialShowDelay="400"
                  PreviewMouseLeftButtonUp="AppIcon_PreviewMouseLeftButtonUp">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Opacity" Value="1.0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <!-- Capture sessions are not click-to-mute, so drop the hand cursor too. -->
                            <DataTrigger Binding="{Binding DataContext.Device.IsCaptureDevice, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                <Setter Property="Cursor" Value="Arrow"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                <Setter Property="Opacity" Value="0.4"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DataContext.Device.IsMuted, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                <Setter Property="Opacity" Value="0.4"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DataContext.Device.IsActive, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </DataTrigger>
                            <!-- DimInactive mode on a capture device: dim icons whose session is not
                                 currently consuming the mic. Matches the SessionRowTemplate triggers. -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding CaptureActivityIndicator, RelativeSource={RelativeSource AncestorType=Window}}" Value="{x:Static models:CaptureActivityIndicator.DimInactive}"/>
                                    <Condition Binding="{Binding DataContext.Device.IsCaptureDevice, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True"/>
                                    <Condition Binding="{Binding State}" Value="{x:Static interop:AudioSessionState.Inactive}"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Opacity" Value="0.4"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding CaptureActivityIndicator, RelativeSource={RelativeSource AncestorType=Window}}" Value="{x:Static models:CaptureActivityIndicator.DimInactive}"/>
                                    <Condition Binding="{Binding DataContext.Device.IsCaptureDevice, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True"/>
                                    <Condition Binding="{Binding State}" Value="{x:Static interop:AudioSessionState.Expired}"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Opacity" Value="0.4"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <!-- Hover background ringing the icon so the click target reads as a button. Sized
                     to AppDrawerHoverPillSize (icon size + 2 px, clamped to GridSlotSize) and
                     centered inside the 36x36 AppIconRoot Grid - the outer Grid keeps the full
                     hit-test region while the visible pill hugs the icon. -->
                <Border CornerRadius="{DynamicResource CornerRadiusMedium}"
                        IsHitTestVisible="False"
                        Width="{Binding AppDrawerHoverPillSize, RelativeSource={RelativeSource AncestorType=Window}}"
                        Height="{Binding AppDrawerHoverPillSize, RelativeSource={RelativeSource AncestorType=Window}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=AppIconRoot}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <Image Source="{Binding Icon}"
                       Width="{Binding AppDrawerIconImageSize, RelativeSource={RelativeSource AncestorType=Window}}"
                       Height="{Binding AppDrawerIconImageSize, RelativeSource={RelativeSource AncestorType=Window}}"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <!-- Placeholder app icon. Mirrors GlyphCatalog.APP_FALLBACK. -->
                <TextBlock Text="{x:Static visuals:GlyphCatalog.APP_FALLBACK}"
                           FontFamily="{StaticResource IconFontFamily}"
                           FontSize="{Binding AppDrawerIconGlyphSize, RelativeSource={RelativeSource AncestorType=Window}}"
                           Foreground="{DynamicResource ThemeIconForeground}"
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <!-- Mute-X hover overlay. Mirrors GlyphCatalog.APP_MUTE_OVERLAY. -->
                <TextBlock IsHitTestVisible="False"
                           Text="{x:Static visuals:GlyphCatalog.APP_MUTE_OVERLAY}"
                           FontFamily="{StaticResource IconFontFamily}"
                           FontSize="{Binding AppDrawerIconGlyphSize, RelativeSource={RelativeSource AncestorType=Window}}"
                           Foreground="{DynamicResource ThemeIconForeground}"
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Opacity" Value="0.5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=AppIconRoot}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <!-- Capture sessions have no useful per-app mute, so suppress the X overlay entirely. -->
                                <DataTrigger Binding="{Binding DataContext.Device.IsCaptureDevice, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Mini-glyph indicator. Capture cells default to a small dot on apps whose session
                     is currently capturing audio; the exclusive-control-holder lock overrides that dot
                     (last trigger wins) so an app holding the parent device in exclusive mode shows
                     LOCK regardless of capture state. Pinned bottom-right inside the slot so the badge
                     sits at a consistent offset regardless of the icon's natural size. -->
                <Grid Width="10" Height="10"
                      HorizontalAlignment="Right" VerticalAlignment="Bottom"
                      Margin="0,0,2,2"
                      IsHitTestVisible="False">
                    <TextBlock FontFamily="{StaticResource IconFontFamily}"
                               FontWeight="ExtraBold"
                               Foreground="{DynamicResource ThemeIconForeground}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value=""/>
                                <Setter Property="FontSize" Value="6"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding CaptureActivityIndicator, RelativeSource={RelativeSource AncestorType=Window}}" Value="{x:Static models:CaptureActivityIndicator.ActiveGlyph}"/>
                                            <Condition Binding="{Binding DataContext.Device.IsCaptureDevice, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True"/>
                                            <Condition Binding="{Binding State}" Value="{x:Static interop:AudioSessionState.Active}"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Text" Value="{x:Static visuals:GlyphCatalog.CIRCLE}"/>
                                    </MultiDataTrigger>
                                    <DataTrigger Binding="{Binding IsExclusiveControlHolder}" Value="True">
                                        <Setter Property="Text" Value="{x:Static visuals:GlyphCatalog.LOCK}"/>
                                        <Setter Property="FontSize" Value="8"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>
        </DataTemplate>

        <!-- Apps band content. ContentControl variant that shows either the slider list or the
             icon grid depending on the cell's UsesGridDrawer. DataContext is the VolumeFlyoutCell.
             A Style with a single DataTrigger swaps the inner template between the two layouts
             without recreating the ContentControl - so toggling RecordingAppDrawerDisplayType at
             runtime is a pure visual swap, no cell rebuild needed.
             IsAppsBottomBand (from the cell) signals that this apps band sits at the flyout's
             bottom edge in the AppsBelow layout; combined with IsLast it triggers the rounded
             footer-bottom corner radius. -->
        <Style x:Key="AppsBandStyle" TargetType="ContentControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Border Background="{DynamicResource ThemeFooterBackground}"
                                Visibility="{Binding HasVisibleGroups, Converter={StaticResource BoolToVisibility}}">
                            <Border.Style>
                                <!-- Round the bottom corners only when this apps band sits flush
                                     against the flyout's outer rounded bottom (AppsBelow + IsLast).
                                     Padding lives in the style (not as a local attribute) so the
                                     AppsBelow flip trigger can override it. -->
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="0"/>
                                    <Setter Property="Padding" Value="14,10,12,0"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsLast}" Value="True"/>
                                                <Condition Binding="{Binding IsAppsBottomBand}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusFooterBottom}"/>
                                        </MultiDataTrigger>
                                        <!-- AppsBelow: drawer sits at the bottom of the cell, so its
                                             breathing room moves from above the slider list to below
                                             it, mirroring the AppsAbove layout. -->
                                        <DataTrigger Binding="{Binding IsAppsBottomBand}" Value="True">
                                            <Setter Property="Padding" Value="14,0,12,10"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <!-- Slider drawer overflow: ScrollViewer caps the rendered height at the
                                 per-device-type SliderDrawerMaxHeight (rows * row pitch). Below the cap the
                                 items render at natural height and the scrollbar stays hidden; past the cap
                                 the implicit app-wide ScrollBar style (the device-list scrollbar) kicks in. -->
                            <ScrollViewer MaxHeight="{Binding SliderDrawerMaxHeight}"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding VisibleGroups}"
                                              ItemTemplate="{StaticResource SessionRowTemplate}"/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Capture cells configured for the icon grid drawer: swap the whole template to
                     the grid variant. CenterMode, columns, stack direction all come from the
                     Window's settings projections via RelativeSource. Padding-bottom 0 matches the
                     slider variant; the cell's container Border absorbs the breathing room. -->
                <DataTrigger Binding="{Binding UsesGridDrawer}" Value="True">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ContentControl">
                                <Border Background="{DynamicResource ThemeFooterBackground}"
                                        Padding="13,0,11,0"
                                        Visibility="{Binding HasVisibleGroups, Converter={StaticResource BoolToVisibility}}">
                                    <Border.Style>
                                        <!-- Margin lives in the style (not as a local attribute) so
                                             the AppsBelow flip trigger can override it. -->
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="0"/>
                                            <Setter Property="Margin" Value="0,-3,0,-4"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsLast}" Value="True"/>
                                                        <Condition Binding="{Binding IsAppsBottomBand}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusFooterBottom}"/>
                                                </MultiDataTrigger>
                                                <!-- AppsBelow: drawer sits at the bottom of the cell, so
                                                     the -2px overlap that tucks the grid into the device
                                                     row moves from the bottom edge to the top edge. -->
                                                <DataTrigger Binding="{Binding IsAppsBottomBand}" Value="True">
                                                    <Setter Property="Margin" Value="0,-2,0,2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <!-- Icon-grid drawer overflow: ScrollViewer caps the rendered height at the
                                         per-device-type GridDrawerMaxHeight (rows * GridSlotSize). In vertical-flow
                                         stack directions the panel's natural height is bounded by perColumn so the
                                         scrollbar usually stays hidden; in horizontal-flow modes the cap kicks in
                                         once rows exceed the user's max-rows setting. -->
                                    <ScrollViewer MaxHeight="{Binding GridDrawerMaxHeight}"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding VisibleGroups}"
                                                      ItemTemplate="{StaticResource GridIconTemplate}"
                                                      HorizontalAlignment="Center">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <wpf:CenteringWrapPanel ItemWidth="{DynamicResource GridSlotSize}"
                                                                            ItemHeight="{DynamicResource GridSlotSize}"
                                                                            Columns="{Binding AppDrawerIconsPerRow, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            CenterMode="{Binding AppDrawerIconsCenterMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            CenterSoftMax="{Binding AppDrawerIconsCenterSoftMax, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            StackDirection="{Binding AppDrawerStackDirection, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Unified cell template. Replaces the four near-identical CellApps*Template variants and
             the DataTemplateSelector that picked among them. Two axes drive layout via cell-level
             properties:
               DeviceRowIndex / AppsRowIndex - flip which Grid.Row hosts the device vs apps band.
               UsesGridDrawer                - the apps band's Style (AppsBandStyle) swaps templates internally.
             Toggling FlyoutDeviceLayout or RecordingAppDrawerDisplayType at runtime now rebinds
             these properties on every live cell and the visuals restyle without a rebuild. -->
        <DataTemplate x:Key="CellTemplate" DataType="{x:Type wpf:VolumeFlyoutCell}">
            <Grid>
                <!-- Faux rounded-card fill. Drawn first so the cell's content paints on top of
                     it. Overflows the cell by 1px each side so the wrapper width matches the
                     flyout's full outer width; ClipToBounds on the parent clips the overflow. -->
                <Border Background="{DynamicResource ThemeFooterBackground}"
                        CornerRadius="{DynamicResource CornerRadiusFlyout}"
                        Margin="-1,0,-1,0"
                        IsHitTestVisible="False"/>

                <!-- Edge breathing room: when this is the topmost or bottommost cell, push the
                     row-bound content inward by 6px and let the cell's fill / outline grow with
                     the wrapper so the rounded card stretches over the new blank space. The
                     MultiDataTrigger handles the single-cell case (IsFirst AND IsLast); it sits
                     last so it wins in WPF's last-matching-trigger order. The wrapper itself has
                     no background, so the padded region shows the fill Border behind it. -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFirst}" Value="True">
                                    <Setter Property="Padding" Value="0,8,0,0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsLast}" Value="True">
                                    <Setter Property="Padding" Value="0,0,0,4"/>
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsFirst}" Value="True"/>
                                        <Condition Binding="{Binding IsLast}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Padding" Value="0,4,0,4"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Apps band slot. Internal style pivots between slider list and icon grid; row
                             position pivots between top (AppsAbove) and bottom (AppsBelow) via the cell. -->
                        <ContentControl Grid.Row="{Binding AppsRowIndex}"
                                        Style="{StaticResource AppsBandStyle}"/>

                        <!-- Device-row slot. Hosts the named DeviceRowTemplate inside a footer-band Border
                             that picks up rounded-bottom corners when this is the last cell AND there's no
                             apps band below it (AppsAbove layout, or AppsBelow with no visible groups). -->
                        <Border Grid.Row="{Binding DeviceRowIndex}"
                                Background="{DynamicResource ThemeFooterBackground}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="0"/>
                                    <Setter Property="Padding" Value="17,4,12,12"/>
                                    <Style.Triggers>
                                        <!-- AppsBelow + last cell + apps band collapsed: this device row is
                                             visually the bottom band, so it rounds its bottom corners. The
                                             padding shifts to match the AppsAbove cell's bottom band so the
                                             content sits at the same offset regardless of layout. -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsAppsBottomBand}" Value="True"/>
                                                <Condition Binding="{Binding HasVisibleGroups}" Value="False"/>
                                                <Condition Binding="{Binding IsLast}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusFooterBottom}"/>
                                        </MultiDataTrigger>
                                        <!-- AppsAbove + last cell: device row sits at the flyout's bottom edge. -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsAppsBottomBand}" Value="False"/>
                                                <Condition Binding="{Binding IsLast}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusFooterBottom}"/>
                                        </MultiDataTrigger>
                                        <!-- AppsBelow non-last cell: extra bottom padding so the device row
                                             hugs the apps band above instead of leaving a gap. -->
                                        <DataTrigger Binding="{Binding IsAppsBottomBand}" Value="True">
                                            <Setter Property="Padding" Value="14,12,12,0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ContentControl Template="{StaticResource DeviceRowTemplate}"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Faux rounded-card outline. Same shape and overflow as the fill above; sits
                     last so the stroke paints on top of everything. No children, so Opacity
                     dims the BorderBrush only. -->
                <Border BorderBrush="{DynamicResource ThemeSliderTrack}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource CornerRadiusFlyout}"
                        Margin="-1,0,-1,0"
                        Opacity="0.4"
                        IsHitTestVisible="False"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <!-- Outer rounded card with drop-shadow. Bubbled (non-preview) mouse handlers drive the
         drag-to-move gesture when undocked. -->
    <Border x:Name="RootCard"
            Background="{DynamicResource ThemeBackground}"
            CornerRadius="{DynamicResource CornerRadiusFlyout}"
            BorderBrush="{DynamicResource ThemeBorder}"
            BorderThickness="1"
            MouseLeftButtonDown="RootCard_MouseLeftButtonDown"
            MouseMove="RootCard_MouseMove"
            MouseLeftButtonUp="RootCard_MouseLeftButtonUp">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.6" Direction="270"/>
        </Border.Effect>

        <!-- DockPanel docks the title bar to whichever edge FlyoutHeaderDock resolves to (top by
             default, bottom when FlyoutHeaderAtBottom is on); the cells Grid is the last child and
             auto-fills the remaining space regardless of which edge the title bar took. The cells
             host stays equivalent to the old Star row - when the window hits its MaxHeight cap the
             fill space gets clamped and the inner ScrollViewer engages. -->
        <DockPanel LastChildFill="True">

            <!-- Title bar. Hosts the left-side Settings button cluster and the right-side undock
                 button. DockPanel.Dock binding flips between Top and Bottom from FlyoutHeaderDock. -->
            <Grid DockPanel.Dock="{Binding FlyoutHeaderDock, RelativeSource={RelativeSource AncestorType=Window}}">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                    <StackPanel.Style>
                        <!-- Margin flips between top-edge and bottom-edge breathing room so the
                             button cluster's reserved gap always sits on the flyout-interior side. -->
                        <Style TargetType="StackPanel">
                            <Setter Property="Margin" Value="3,6,0,0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FlyoutHeaderDock, RelativeSource={RelativeSource AncestorType=Window}}" Value="Bottom">
                                    <Setter Property="Margin" Value="3,0,0,6"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button x:Name="SettingsButton"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            Click="SettingsButton_Click"
                            ToolTip="{loc:Loc Flyout_Settings_Tooltip}">
                        <TextBlock Text="{DynamicResource GlyphSettings}"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="19"
                                   Foreground="{DynamicResource ThemeIconForeground}"/>
                    </Button>
                    <Button x:Name="SoundSettingsButton"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            Click="SoundSettingsButton_Click"
                            ToolTip="{loc:Loc Flyout_SoundSettings_Tooltip}">
                        <!-- Sound-settings entrypoint glyph. Mirrors GlyphCatalog.SOUND_SETTINGS. -->
                        <TextBlock Text="{x:Static visuals:GlyphCatalog.SOUND_SETTINGS}"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="19"
                                   Foreground="{DynamicResource ThemeIconForeground}"/>
                    </Button>
                    <Button Style="{StaticResource HeaderIconButtonStyle}" IsEnabled="False"/>
                    <Button Style="{StaticResource HeaderIconButtonStyle}" IsEnabled="False"/>
                </StackPanel>

                <Button x:Name="UndockButton"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="UndockButton_Click"
                        PreviewMouseLeftButtonDown="UndockButton_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="UndockButton_PreviewMouseMove"
                        PreviewMouseLeftButtonUp="UndockButton_PreviewMouseLeftButtonUp"
                        Visibility="{Binding AllowFlyoutUndock, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                    <Button.Style>
                        <!-- BasedOn pulls the HeaderIconButtonStyle visuals; the trigger flips the
                             Margin between top-edge and bottom-edge breathing room. -->
                        <Style TargetType="Button" BasedOn="{StaticResource HeaderIconButtonStyle}">
                            <Setter Property="Margin" Value="0,3,7,1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FlyoutHeaderDock, RelativeSource={RelativeSource AncestorType=Window}}" Value="Bottom">
                                    <Setter Property="Margin" Value="0,0,7,6"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Resources>
                        <Style TargetType="ToolTip">
                            <Setter Property="Placement" Value="Bottom"/>
                        </Style>
                    </Button.Resources>
                    <Button.ToolTip>
                        <ToolTip>
                            <ToolTip.Style>
                                <Style TargetType="ToolTip">
                                    <Setter Property="Content" Value="{loc:Loc Flyout_Undock_Tooltip}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUndocked, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                            <Setter Property="Content" Value="{loc:Loc Flyout_Redock_Tooltip}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ToolTip.Style>
                        </ToolTip>
                    </Button.ToolTip>
                    <!-- Undock action glyph; flips to redock when the flyout is already undocked.
                         Mirrors GlyphCatalog.FLYOUT_UNDOCK_ACTION / FLYOUT_REDOCK_ACTION. -->
                    <TextBlock FontFamily="{StaticResource IconFontFamily}"
                               FontSize="20"
                               Foreground="{DynamicResource ThemeIconForeground}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{x:Static visuals:GlyphCatalog.FLYOUT_UNDOCK_ACTION}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUndocked, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Text" Value="{x:Static visuals:GlyphCatalog.FLYOUT_REDOCK_ACTION}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </Grid>

            <!-- Device cell list. Each cell is one render or capture endpoint, ordered by
                 FlyoutDeviceOrdering. Empty-state overlay sits in the same row so it occupies the
                 empty space without forcing a height jump on first cell arrival. ClipToBounds
                 hides the vertical sides of each cell's faux-card outline Border, which overflows
                 the cell area by 1px each side - only the top / bottom edges with their rounded
                 corners survive into the visible region. Last child of the DockPanel so it fills
                 whatever space the title bar didn't claim, no matter which edge took the bar. -->
            <Grid ClipToBounds="True">
                <ScrollViewer x:Name="CellsScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Focusable="False">
                    <ItemsControl x:Name="CellsList"
                                  ItemsSource="{Binding Cells, RelativeSource={RelativeSource AncestorType=Window}}"
                                  ItemTemplate="{StaticResource CellTemplate}"/>
                </ScrollViewer>

                <TextBlock Text="No audio devices"
                           Foreground="{DynamicResource ThemeSecondaryForeground}"
                           FontSize="13"
                           Opacity="0.7"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,18,0,18">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasCells, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </DockPanel>
    </Border>
</Window>
