<Window
    x:Class="VolumeTrayAppWPF.WPF.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:pages="clr-namespace:VolumeTrayAppWPF.WPF.Settings.Pages"
    xmlns:utils="clr-namespace:VolumeTrayAppWPF.WPF.Utils"
    xmlns:visuals="clr-namespace:VolumeTrayAppWPF.Visuals"
    xmlns:loc="clr-namespace:VolumeTrayAppWPF.Localization"
    utils:KeyboardFocusBehavior.EnableKeyboardOnlyFocus="True"
    utils:KeyboardFocusBehavior.FocusStyle="{StaticResource KeyboardFocusVisualStyle}"
    utils:SettingsKeyboardNavigation.Enable="True"
    Title="{loc:Loc SettingsWindow_Title}"
    Width="960"
    Height="670"
    MinWidth="720"
    MinHeight="520"
    Background="{DynamicResource ThemeBackground}"
    Foreground="{DynamicResource ThemeForeground}"
    WindowStyle="None"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    TextElement.FontFamily="Segoe UI Variable, Segoe UI"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder"
            Background="{DynamicResource ThemeBackground}"
            BorderBrush="{DynamicResource ThemeBorder}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- === TITLE BAR === -->
            <Grid Grid.Row="0" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Caption Buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeButton"
                            Style="{StaticResource CaptionButtonStyle}"
                            Click="Minimize_Click"
                            Content="{x:Static visuals:GlyphCatalog.CHROME_MINIMIZE}"
                            ToolTip="{loc:Loc SettingsWindow_Caption_Minimize}"/>
                    <Button x:Name="MaximizeButton"
                            Style="{StaticResource CaptionButtonStyle}"
                            Click="Maximize_Click"
                            Content="{x:Static visuals:GlyphCatalog.CHROME_MAXIMIZE}"
                            ToolTip="{loc:Loc SettingsWindow_Caption_Maximize}"/>
                    <Button x:Name="CloseButton"
                            Style="{StaticResource CaptionCloseButtonStyle}"
                            Click="Close_Click"
                            Content="{x:Static visuals:GlyphCatalog.EXIT}"
                            ToolTip="{loc:Loc SettingsWindow_Caption_Close}"/>
                </StackPanel>
            </Grid>

            <!-- === BODY === -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT NAV -->
                <Grid Grid.Column="0" Background="Transparent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{loc:Loc SettingsWindow_Header}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeForeground}"
                               Margin="24,8,20,20"/>

                    <StackPanel Grid.Row="1" Margin="8,0"
                                utils:SettingsKeyboardNavigation.IsNavigationSidebar="True">
                        <RadioButton x:Name="NavGeneral"
                                     Style="{StaticResource NavItemStyle}"
                                     Content="{loc:Loc Settings_Common_Tab_General}"
                                     IsChecked="True"
                                     Checked="NavItem_Checked"
                                     Tag="General"
                                     GroupName="SettingsNav"/>
                        <RadioButton x:Name="NavFlyout"
                                     Style="{StaticResource NavItemStyle}"
                                     Content="{loc:Loc Settings_Common_Tab_Flyout}"
                                     Checked="NavItem_Checked"
                                     Tag="Flyout"
                                     GroupName="SettingsNav"/>
                        <RadioButton x:Name="NavDeviceAppDrawers"
                                     Style="{StaticResource NavItemStyle}"
                                     Content="{loc:Loc Settings_Common_Tab_DeviceAppDrawers}"
                                     Checked="NavItem_Checked"
                                     Tag="DeviceAppDrawers"
                                     GroupName="SettingsNav"/>
                        <RadioButton x:Name="NavTrayIcon"
                                     Style="{StaticResource NavItemStyle}"
                                     Content="{loc:Loc Settings_Common_Tab_TrayIcon}"
                                     Checked="NavItem_Checked"
                                     Tag="TrayIcon"
                                     GroupName="SettingsNav"/>
                        <RadioButton x:Name="NavDevices"
                                     Style="{StaticResource NavItemStyle}"
                                     Content="{loc:Loc Settings_Common_Tab_Devices}"
                                     Checked="NavItem_Checked"
                                     Tag="Devices"
                                     GroupName="SettingsNav"/>
                        <RadioButton x:Name="NavHotkeys"
                                     Style="{StaticResource NavItemStyle}"
                                     Content="{loc:Loc Settings_Common_Tab_Hotkeys}"
                                     Checked="NavItem_Checked"
                                     Tag="Hotkeys"
                                     GroupName="SettingsNav"/>
                        <RadioButton x:Name="NavTheme"
                                     Style="{StaticResource NavItemStyle}"
                                     Content="{loc:Loc Settings_Common_Tab_Theme}"
                                     Checked="NavItem_Checked"
                                     Tag="Theme"
                                     GroupName="SettingsNav"/>
                        <RadioButton x:Name="NavAbout"
                                     Style="{StaticResource NavItemStyle}"
                                     Content="{loc:Loc Settings_Common_Tab_About}"
                                     Checked="NavItem_Checked"
                                     Tag="About"
                                     GroupName="SettingsNav"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="8,0,8,12">
                        <Button x:Name="OpenSettingsFolderButton"
                                Style="{StaticResource NavActionStyle}"
                                Content="{loc:Loc SettingsWindow_OpenSettingsFolder}"
                                Click="OpenSettingsFolder_Click"
                                utils:SettingsKeyboardNavigation.IsSidebarFooter="True"/>
                    </StackPanel>
                </Grid>

                <!-- CONTENT -->
                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="24,4,30,28">
                    <Grid>
                        <!-- General -->
                        <pages:GeneralPage x:Name="GeneralSection" Visibility="Visible"/>

                        <!-- Flyout -->
                        <pages:FlyoutPage x:Name="FlyoutSection" Visibility="Collapsed"/>

                        <!-- Device App Drawers -->
                        <pages:DeviceAppDrawersPage x:Name="DeviceAppDrawersSection" Visibility="Collapsed"/>

                        <!-- Tray Icon -->
                        <pages:TrayIconPage x:Name="TrayIconSection" Visibility="Collapsed"/>

                        <!-- Devices -->
                        <pages:DevicesPage x:Name="DevicesSection" Visibility="Collapsed"/>

                        <!-- Hotkeys -->
                        <pages:HotkeysPage x:Name="HotkeysSection" Visibility="Collapsed"/>

                        <!-- Theme -->
                        <pages:ThemePage x:Name="ThemeSection" Visibility="Collapsed"/>

                        <!-- About / Misc -->
                        <pages:AboutPage x:Name="AboutSection" Visibility="Collapsed"/>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- === Confirmation overlay (shown for destructive actions like Clear Displays) === -->
            <!-- Scrim uses the theme-derived backdrop brush so a future light/dark variant flows
                 through ThemeResources.Apply without touching this file. -->
            <Grid x:Name="ConfirmOverlay"
                  Grid.Row="1"
                  Visibility="Collapsed"
                  Background="{DynamicResource FlyoutOverlayBackdropBrush}">
                <Border Background="{DynamicResource ThemeCardBackground}"
                        BorderBrush="{DynamicResource ThemeBorder}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource CornerRadiusLarge}"
                        Padding="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MinWidth="360"
                        MaxWidth="460">
                    <StackPanel>
                        <TextBlock x:Name="ConfirmOverlayTitle"
                                   Text="{loc:Loc SettingsWindow_ConfirmOverlay_DefaultTitle}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeForeground}"
                                   Margin="0,0,0,8"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="ConfirmOverlayMessage"
                                   Text="{loc:Loc SettingsWindow_ConfirmOverlay_DefaultMessage}"
                                   Style="{StaticResource SettingDescriptionStyle}"
                                   Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="ConfirmOverlayCancelButton"
                                    Style="{StaticResource SettingsButtonStyle}"
                                    Content="{loc:Loc SettingsWindow_ConfirmOverlay_Cancel}"
                                    Margin="{StaticResource RightSpacerSmall}"
                                    Click="ConfirmOverlayCancel_Click"/>
                            <Button x:Name="ConfirmOverlayConfirmButton"
                                    Style="{StaticResource SettingsButtonStyle}"
                                    Content="{loc:Loc SettingsWindow_ConfirmOverlay_Confirm}"
                                    Click="ConfirmOverlayConfirm_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Border>
</Window>
