<UserControl
    x:Class="VolumeTrayAppWPF.WPF.Settings.Pages.DevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:VolumeTrayAppWPF.WPF.Settings.Utils"
    xmlns:utils1="clr-namespace:VolumeTrayAppWPF.WPF.Utils"
    xmlns:models="clr-namespace:VolumeTrayAppWPF.Models"
    xmlns:loc="clr-namespace:VolumeTrayAppWPF.Localization"
    mc:Ignorable="d"
    d:DesignWidth="660"
    d:DesignHeight="900"
    d:Background="#1F1F1F"
    d:DataContext="{d:DesignInstance Type=models:AppSettings, IsDesignTimeCreatable=False}"
    utils1:SettingsKeyboardNavigation.IsContentSection="True">
    <UserControl.Resources>
        <!-- Page-scoped because App.xaml only ships BoolToVisibility; the inverse + AND-of-bools
             converters are only needed for the cascading "even if disabled" gates on this page. -->
        <utils1:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <utils1:AndBoolToVisibilityConverter x:Key="AndBoolToVisibility"/>
    </UserControl.Resources>
    <StackPanel>
        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="{loc:Loc Settings_Devices_SectionHeader}"/>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_SetDefaultCommsToDefault_Title}"
                            Description="{loc:Loc Settings_Devices_SetDefaultCommsToDefault_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="SetDefaultCommsToDefaultToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="SetDefaultCommsToDefault" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <TextBlock Text="{loc:Loc Settings_Devices_Playback_Header}" Style="{StaticResource SubsectionHeaderStyle}"/>

        <utils:SettingsCard x:Name="PlayDeviceVolumeChangeSoundCard"
                            Title="{loc:Loc Settings_Devices_PlayDeviceVolumeChangeSound_Title}"
                            Description="{loc:Loc Settings_Devices_PlayDeviceVolumeChangeSound_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="PlayDeviceVolumeChangeSoundToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="PlayDeviceVolumeChangeSound"
                          Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <TextBlock Text="{loc:Loc Settings_Devices_Visibility_Header}" Style="{StaticResource SubsectionHeaderStyle}"/>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowDisabledPlayback_Title}"
                            Description="{loc:Loc Settings_Devices_ShowDisabledPlayback_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowDisabledPlaybackToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowDisabledPlaybackDevices" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <!-- "Even if disabled" entries are only meaningful while the broad disabled gate is OFF.
             Hide them when ShowDisabledPlaybackDevices is on so the off-state UI stays uncluttered.
             Visibility bound through the InverseBool converter so it follows the parent toggle live. -->
        <utils:SettingsCard x:Name="ShowDefaultPlaybackEvenIfDisabledCard"
                            Title="{loc:Loc Settings_Devices_ShowDefaultPlaybackEvenIfDisabled_Title}"
                            Description="{loc:Loc Settings_Devices_ShowDefaultPlaybackEvenIfDisabled_Description}"
                            Visibility="{Binding IsChecked, ElementName=ShowDisabledPlaybackToggle, Converter={StaticResource InverseBoolToVisibility}}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowDefaultPlaybackEvenIfDisabledToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowDefaultPlaybackDeviceEvenIfDisabled" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard x:Name="ShowDefaultCommsPlaybackEvenIfDisabledCard"
                            Title="{loc:Loc Settings_Devices_ShowDefaultCommsPlaybackEvenIfDisabled_Title}"
                            Description="{loc:Loc Settings_Devices_ShowDefaultCommsPlaybackEvenIfDisabled_Description}"
                            Visibility="{Binding IsChecked, ElementName=ShowDisabledPlaybackToggle, Converter={StaticResource InverseBoolToVisibility}}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowDefaultCommsPlaybackEvenIfDisabledToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowDefaultCommsPlaybackDeviceEvenIfDisabled" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowDisconnectedPlayback_Title}"
                            Description="{loc:Loc Settings_Devices_ShowDisconnectedPlayback_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowDisconnectedPlaybackToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowDisconnectedPlaybackDevices" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <TextBlock Text="{loc:Loc Settings_Devices_RecordingVisibility_Header}" Style="{StaticResource SubsectionHeaderStyle}"/>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowRecording_Title}"
                            Description="{loc:Loc Settings_Devices_ShowRecording_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowRecordingToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowRecordingDevices" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <!-- Recording-side children: hidden whenever the master ShowRecordingDevices is off so the
             off-state UI doesn't dangle dead toggles. The "even if disabled" pair is further gated
             on ShowDisabledRecordingDevices being off, mirroring the playback section above.
             Visibility flows from XAML bindings against the parent toggles, no imperative refresh. -->
        <utils:SettingsCard x:Name="ShowDisabledRecordingCard"
                            Title="{loc:Loc Settings_Devices_ShowDisabledRecording_Title}"
                            Description="{loc:Loc Settings_Devices_ShowDisabledRecording_Description}"
                            Visibility="{Binding IsChecked, ElementName=ShowRecordingToggle, Converter={StaticResource BoolToVisibility}}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowDisabledRecordingToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowDisabledRecordingDevices" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard x:Name="ShowDefaultRecordingEvenIfDisabledCard"
                            Title="{loc:Loc Settings_Devices_ShowDefaultRecordingEvenIfDisabled_Title}"
                            Description="{loc:Loc Settings_Devices_ShowDefaultRecordingEvenIfDisabled_Description}">
            <utils:SettingsCard.Visibility>
                <MultiBinding Converter="{StaticResource AndBoolToVisibility}"
                              ConverterParameter="01">
                    <Binding ElementName="ShowRecordingToggle" Path="IsChecked"/>
                    <Binding ElementName="ShowDisabledRecordingToggle" Path="IsChecked"/>
                </MultiBinding>
            </utils:SettingsCard.Visibility>
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowDefaultRecordingEvenIfDisabledToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowDefaultRecordingDeviceEvenIfDisabled" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard x:Name="ShowDefaultCommsRecordingEvenIfDisabledCard"
                            Title="{loc:Loc Settings_Devices_ShowDefaultCommsRecordingEvenIfDisabled_Title}"
                            Description="{loc:Loc Settings_Devices_ShowDefaultCommsRecordingEvenIfDisabled_Description}">
            <utils:SettingsCard.Visibility>
                <MultiBinding Converter="{StaticResource AndBoolToVisibility}"
                              ConverterParameter="01">
                    <Binding ElementName="ShowRecordingToggle" Path="IsChecked"/>
                    <Binding ElementName="ShowDisabledRecordingToggle" Path="IsChecked"/>
                </MultiBinding>
            </utils:SettingsCard.Visibility>
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowDefaultCommsRecordingEvenIfDisabledToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowDefaultCommsRecordingDeviceEvenIfDisabled" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <!-- NotPresent (registry-only) endpoints. Cross-flow: applies to both render and capture
             ghosts in one switch. Off by default so the flyout / tray-menu don't drown in
             "Unknown Device" rows for every USB DAC port the user has ever plugged in. -->
        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowNotPresent_Title}"
                            Description="{loc:Loc Settings_Devices_ShowNotPresent_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowNotPresentToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowNotPresentDevices" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <!-- Per-device-row button visibility. Two parallel sections so a user can declutter playback and
             recording rows independently. Each toggle hides one button on rows of the matching device type.
             Listen is recording-only by nature, so it lives only in the recording section. -->
        <TextBlock Text="{loc:Loc Settings_Devices_PlaybackButtons_Header}" Style="{StaticResource SubsectionHeaderStyle}"/>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowPlaybackLockButton_Title}"
                            Description="{loc:Loc Settings_Devices_ShowPlaybackLockButton_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowPlaybackLockButtonToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowLockButtonForPlayback" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowPlaybackEqualizerAPOButton_Title}"
                            Description="{loc:Loc Settings_Devices_ShowPlaybackEqualizerAPOButton_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowPlaybackEqualizerAPOButtonToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowEqualizerAPOButtonForPlayback" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowPlaybackDefaultDeviceButton_Title}"
                            Description="{loc:Loc Settings_Devices_ShowPlaybackDefaultDeviceButton_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowPlaybackDefaultDeviceButtonToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowDefaultDeviceButtonForPlayback" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowPlaybackBatteryButton_Title}"
                            Description="{loc:Loc Settings_Devices_ShowPlaybackBatteryButton_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowPlaybackBatteryButtonToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowBatteryButtonForPlayback" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <TextBlock Text="{loc:Loc Settings_Devices_RecordingButtons_Header}" Style="{StaticResource SubsectionHeaderStyle}"/>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowRecordingLockButton_Title}"
                            Description="{loc:Loc Settings_Devices_ShowRecordingLockButton_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowRecordingLockButtonToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowLockButtonForRecording" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowRecordingEqualizerAPOButton_Title}"
                            Description="{loc:Loc Settings_Devices_ShowRecordingEqualizerAPOButton_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowRecordingEqualizerAPOButtonToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowEqualizerAPOButtonForRecording" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowRecordingListenButton_Title}"
                            Description="{loc:Loc Settings_Devices_ShowRecordingListenButton_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowRecordingListenButtonToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowListenButtonForRecording" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowRecordingDefaultDeviceButton_Title}"
                            Description="{loc:Loc Settings_Devices_ShowRecordingDefaultDeviceButton_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowRecordingDefaultDeviceButtonToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowDefaultDeviceButtonForRecording" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowRecordingBatteryButton_Title}"
                            Description="{loc:Loc Settings_Devices_ShowRecordingBatteryButton_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowRecordingBatteryButtonToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowBatteryButtonForRecording" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>
    </StackPanel>
</UserControl>
