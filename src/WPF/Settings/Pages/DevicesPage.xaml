<UserControl
    x:Class="VolumeTrayAppWPF.WPF.Settings.Pages.DevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:VolumeTrayAppWPF.WPF.Settings.Utils"
    xmlns:utils1="clr-namespace:VolumeTrayAppWPF.WPF.Utils"
    xmlns:loc="clr-namespace:VolumeTrayAppWPF.Localization"
    mc:Ignorable="d"
    d:DesignWidth="660"
    d:DesignHeight="900"
    d:Background="#1F1F1F"
    utils1:SettingsKeyboardNavigation.IsContentSection="True">
    <StackPanel>
        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="{loc:Loc Settings_Devices_SectionHeader}"/>

        <TextBlock Text="{loc:Loc Settings_Devices_Defaulting_Header}" Style="{StaticResource SubsectionHeaderStyle}"/>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_SetDefaultCommsToDefault_Title}"
                            Description="{loc:Loc Settings_Devices_SetDefaultCommsToDefault_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="SetDefaultCommsToDefaultToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="SetDefaultCommsToDefault" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <TextBlock Text="{loc:Loc Settings_Devices_Visibility_Header}" Style="{StaticResource SubsectionHeaderStyle}"/>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowDisabledPlayback_Title}"
                            Description="{loc:Loc Settings_Devices_ShowDisabledPlayback_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowDisabledPlaybackToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowDisabledPlaybackDevices" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <!-- "Even if disabled" entries are only meaningful while the broad disabled gate is OFF.
             Hide them when ShowDisabledPlaybackDevices is on so the off-state UI stays uncluttered. -->
        <utils:SettingsCard x:Name="ShowDefaultPlaybackEvenIfDisabledCard"
                            Title="{loc:Loc Settings_Devices_ShowDefaultPlaybackEvenIfDisabled_Title}"
                            Description="{loc:Loc Settings_Devices_ShowDefaultPlaybackEvenIfDisabled_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowDefaultPlaybackEvenIfDisabledToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowDefaultPlaybackDeviceEvenIfDisabled" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard x:Name="ShowDefaultCommsPlaybackEvenIfDisabledCard"
                            Title="{loc:Loc Settings_Devices_ShowDefaultCommsPlaybackEvenIfDisabled_Title}"
                            Description="{loc:Loc Settings_Devices_ShowDefaultCommsPlaybackEvenIfDisabled_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowDefaultCommsPlaybackEvenIfDisabledToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowDefaultCommsPlaybackDeviceEvenIfDisabled" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowDisconnectedPlayback_Title}"
                            Description="{loc:Loc Settings_Devices_ShowDisconnectedPlayback_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowDisconnectedPlaybackToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowDisconnectedPlaybackDevices" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <TextBlock Text="{loc:Loc Settings_Devices_RecordingVisibility_Header}" Style="{StaticResource SubsectionHeaderStyle}"/>

        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowRecording_Title}"
                            Description="{loc:Loc Settings_Devices_ShowRecording_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowRecordingToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowRecordingDevices" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <!-- Recording-side children: hidden whenever the master ShowRecordingDevices is off so the
             off-state UI doesn't dangle dead toggles. The "even if disabled" pair is further gated
             on ShowDisabledRecordingDevices being off, mirroring the playback section above. -->
        <utils:SettingsCard x:Name="ShowDisabledRecordingCard"
                            Title="{loc:Loc Settings_Devices_ShowDisabledRecording_Title}"
                            Description="{loc:Loc Settings_Devices_ShowDisabledRecording_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowDisabledRecordingToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowDisabledRecordingDevices" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard x:Name="ShowDefaultRecordingEvenIfDisabledCard"
                            Title="{loc:Loc Settings_Devices_ShowDefaultRecordingEvenIfDisabled_Title}"
                            Description="{loc:Loc Settings_Devices_ShowDefaultRecordingEvenIfDisabled_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowDefaultRecordingEvenIfDisabledToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowDefaultRecordingDeviceEvenIfDisabled" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard x:Name="ShowDefaultCommsRecordingEvenIfDisabledCard"
                            Title="{loc:Loc Settings_Devices_ShowDefaultCommsRecordingEvenIfDisabled_Title}"
                            Description="{loc:Loc Settings_Devices_ShowDefaultCommsRecordingEvenIfDisabled_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowDefaultCommsRecordingEvenIfDisabledToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowDefaultCommsRecordingDeviceEvenIfDisabled" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <!-- NotPresent (registry-only) endpoints. Cross-flow: applies to both render and capture
             ghosts in one switch. Off by default so the flyout / tray-menu don't drown in
             "Unknown Device" rows for every USB DAC port the user has ever plugged in. -->
        <utils:SettingsCard Title="{loc:Loc Settings_Devices_ShowNotPresent_Title}"
                            Description="{loc:Loc Settings_Devices_ShowNotPresent_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="ShowNotPresentToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowNotPresentDevices" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>
    </StackPanel>
</UserControl>
