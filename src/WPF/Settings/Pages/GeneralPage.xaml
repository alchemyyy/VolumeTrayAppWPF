<UserControl
    x:Class="VolumeTrayAppWPF.WPF.Settings.Pages.GeneralPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:VolumeTrayAppWPF.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:VolumeTrayAppWPF.Models"
    xmlns:utils="clr-namespace:VolumeTrayAppWPF.WPF.Settings.Utils"
    xmlns:utils1="clr-namespace:VolumeTrayAppWPF.WPF.Utils"
    xmlns:loc="clr-namespace:VolumeTrayAppWPF.Localization"
    mc:Ignorable="d"
    d:DesignWidth="660"
    d:DesignHeight="594"
    d:Background="#1F1F1F"
    d:DataContext="{d:DesignInstance Type=models:AppSettings, IsDesignTimeCreatable=False}"
    utils1:SettingsKeyboardNavigation.IsContentSection="True">
    <StackPanel>
        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="{loc:Loc Settings_General_SectionHeader}"/>

        <utils:SettingsCard x:Name="RunOnStartupCard"
                               Title="{loc:Loc Settings_General_RunOnStartup_Title}"
                               Description="{loc:Loc Settings_General_RunOnStartup_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="RunOnStartupToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Checked="RunOnStartup_Changed"
                          Unchecked="RunOnStartup_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <TextBlock Text="{loc:Loc Settings_General_Installation_Header}"
                   Style="{StaticResource SubsectionHeaderStyle}"/>

        <!-- Install rows. Status string flows into SettingsCard.Description from code-behind
             (RefreshInstallationSection); the button-pair sits in SettingsCard.Control. Install /
             Uninstall buttons toggle Visibility based on InstallStatus, set imperatively. -->
        <utils:SettingsCard x:Name="InstallLocalAppDataCard"
                            Title="{loc:Loc Settings_General_LocalUser_Title}">
            <utils:SettingsCard.Control>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="InstallLocalAppDataButton"
                            Style="{StaticResource SettingsButtonStyle}"
                            Content="{loc:Loc Settings_General_Install_Button}"
                            Margin="{StaticResource RightSpacerSmall}"
                            Click="InstallLocalAppData_Click"/>
                    <Button x:Name="UninstallLocalAppDataButton"
                            Style="{StaticResource SettingsButtonStyle}"
                            Content="{loc:Loc Settings_General_Uninstall_Button}"
                            Click="UninstallLocalAppData_Click"/>
                </StackPanel>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard x:Name="InstallProgramFilesCard"
                            Title="{loc:Loc Settings_General_SystemWide_Title}">
            <utils:SettingsCard.Control>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="InstallProgramFilesButton"
                            Style="{StaticResource SettingsButtonStyle}"
                            Content="{loc:Loc Settings_General_Install_Button}"
                            Margin="{StaticResource RightSpacerSmall}"
                            Click="InstallProgramFiles_Click"/>
                    <Button x:Name="UninstallProgramFilesButton"
                            Style="{StaticResource SettingsButtonStyle}"
                            Content="{loc:Loc Settings_General_Uninstall_Button}"
                            Click="UninstallProgramFiles_Click"/>
                </StackPanel>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard x:Name="InstallStoreCard"
                            Title="{loc:Loc Settings_General_WindowsStore_Title}"/>

        <TextBlock Text="{loc:Loc Settings_General_Notifications_Header}"
                   Style="{StaticResource SubsectionHeaderStyle}"/>

        <utils:SettingsCard x:Name="PlayDeviceVolumeChangeSoundCard"
                               Title="{loc:Loc Settings_General_PlayDeviceVolumeChangeSound_Title}"
                               Description="{loc:Loc Settings_General_PlayDeviceVolumeChangeSound_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="PlayDeviceVolumeChangeSoundToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="PlayDeviceVolumeChangeSound"
                          Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard x:Name="PlayAppVolumeChangeSoundCard"
                               Title="{loc:Loc Settings_General_PlayAppVolumeChangeSound_Title}"
                               Description="{loc:Loc Settings_General_PlayAppVolumeChangeSound_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="PlayAppVolumeChangeSoundToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="PlayAppVolumeChangeSound"
                          Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <TextBlock Text="{loc:Loc Settings_General_PeakMeter_Header}"
                   Style="{StaticResource SubsectionHeaderStyle}"/>

        <utils:SettingsCard Title="{loc:Loc Settings_Theme_UnifiedPeakMeter_Title}"
                               Description="{loc:Loc Settings_Theme_UnifiedPeakMeter_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="UnifiedPeakMeterToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="UnifiedPeakMeter" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <!-- Bias multiplier card. Only meaningful while UnifiedPeakMeter is on, so visibility is
             gated on the toggle's IsChecked - hidden when off so the off-state UI stays uncluttered. -->
        <utils:SettingsCard x:Name="UnifiedMeterBiasCard"
                            Title="{loc:Loc Settings_Theme_UnifiedMeterBias_Title}"
                            Description="{loc:Loc Settings_Theme_UnifiedMeterBias_Description}"
                            Visibility="{Binding IsChecked, ElementName=UnifiedPeakMeterToggle, Converter={StaticResource BoolToVisibility}}">
            <utils:SettingsCard.Control>
                <local:NumericSpinner x:Name="UnifiedMeterBiasBox"
                                      Minimum="{x:Static models:AppSettings.UnifiedMeterLowChannelBiasMultiplierMin}"
                                      Maximum="{x:Static models:AppSettings.UnifiedMeterLowChannelBiasMultiplierMax}"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Theme_MeterPeakFps_Title}"
                               Description="{loc:Loc Settings_Theme_MeterPeakFps_Description}">
            <utils:SettingsCard.Control>
                <local:NumericSpinner x:Name="MeterPeakFpsBox"
                                      Minimum="{x:Static models:AppSettings.MeterPeakFpsMin}"
                                      Maximum="{x:Static models:AppSettings.MeterPeakFpsMax}"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Theme_MeterPeakSampleRate_Title}"
                               Description="{loc:Loc Settings_Theme_MeterPeakSampleRate_Description}">
            <utils:SettingsCard.Control>
                <local:NumericSpinner x:Name="MeterPeakSampleRateBox"
                                      Minimum="{x:Static models:AppSettings.MeterPeakSampleRateMin}"
                                      Maximum="{x:Static models:AppSettings.MeterPeakSampleRateMax}"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Theme_MeterPeakChangeCeiling_Title}"
                               Description="{loc:Loc Settings_Theme_MeterPeakChangeCeiling_Description}">
            <utils:SettingsCard.Control>
                <local:NumericSpinner x:Name="MeterPeakChangeCeilingBox"
                                      Minimum="{x:Static models:AppSettings.MeterPeakChangeCeilingMin}"
                                      Maximum="{x:Static models:AppSettings.MeterPeakChangeCeilingMax}"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <TextBlock Text="{loc:Loc Settings_General_AppIcons_Header}"
                   Style="{StaticResource SubsectionHeaderStyle}"/>

        <utils:SettingsCard Title="{loc:Loc Settings_General_IconRetryInterval_Title}"
                               Description="{loc:Loc Settings_General_IconRetryInterval_Description}">
            <utils:SettingsCard.Control>
                <local:NumericSpinner x:Name="IconRetryIntervalBox"
                                      Minimum="{x:Static models:AppSettings.IconRetryIntervalMsMin}"
                                      Maximum="{x:Static models:AppSettings.IconRetryIntervalMsMax}"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard x:Name="LogarithmicVolumeScaleCard"
                               Title="{loc:Loc Settings_General_LogarithmicVolumeScale_Title}"
                               Description="{loc:Loc Settings_General_LogarithmicVolumeScale_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="LogarithmicVolumeScaleToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="UseLogarithmicVolumeScale"
                          Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>
    </StackPanel>
</UserControl>
