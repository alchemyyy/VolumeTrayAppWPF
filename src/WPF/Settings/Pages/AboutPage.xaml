<UserControl
    x:Class="VolumeTrayAppWPF.WPF.Settings.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:loc="clr-namespace:VolumeTrayAppWPF.Localization"
    xmlns:local="clr-namespace:VolumeTrayAppWPF.WPF"
    xmlns:models="clr-namespace:VolumeTrayAppWPF.Models"
    xmlns:utils="clr-namespace:VolumeTrayAppWPF.WPF.Utils"
    xmlns:settingsUtils="clr-namespace:VolumeTrayAppWPF.WPF.Settings.Utils"
    mc:Ignorable="d"
    d:DesignWidth="660"
    d:DesignHeight="900"
    d:Background="#1F1F1F"
    d:DataContext="{d:DesignInstance Type=models:AppSettings, IsDesignTimeCreatable=False}"
    utils:SettingsKeyboardNavigation.IsContentSection="True">
    <UserControl.Resources>
        <!-- Page-scoped implicit TextBlock style: every label / value cell on this page reads from
             ThemeForeground, so hoist the per-element Foreground attribute out. Applies only to
             TextBlocks without an explicit Style assignment; the keyed SectionHeaderStyle and
             AboutLabelStyle already set Foreground themselves. Hyperlink is not a TextBlock and
             keeps its inline brush. -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ThemeForeground}"/>
        </Style>
    </UserControl.Resources>
    <StackPanel>
        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="{loc:Loc Settings_About_SectionHeader}"/>

        <TextBlock Text="VolumeTrayAppWPF"
                   FontSize="14"
                   FontWeight="Normal"
                   Margin="0,0,0,4"/>

        <TextBlock Text="{loc:Loc Settings_About_Tagline}"
                   Opacity="0.7"
                   TextWrapping="Wrap"
                   Margin="0,0,0,24"/>

        <StackPanel Orientation="Horizontal" Margin="{StaticResource AboutRowMargin}">
            <TextBlock Text="{loc:Loc Settings_About_BuildLabel}"
                       Style="{StaticResource AboutLabelStyle}"/>
            <TextBlock x:Name="BuildNumberText"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="{StaticResource AboutRowMargin}">
            <TextBlock Text="{loc:Loc Settings_About_RuntimeLabel}"
                       Style="{StaticResource AboutLabelStyle}"/>
            <TextBlock x:Name="RuntimeText"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="{StaticResource AboutRowMargin}">
            <TextBlock Text="{loc:Loc Settings_About_AuthorLabel}"
                       Style="{StaticResource AboutLabelStyle}"/>
            <TextBlock Text="alchemyyy"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="{StaticResource AboutRowMargin}">
            <TextBlock Text="{loc:Loc Settings_About_GithubLabel}"
                       Style="{StaticResource AboutLabelStyle}"/>
            <TextBlock>
                <Hyperlink NavigateUri="https://github.com/alchemyyy/VolumeTrayAppWPF"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="{DynamicResource ThemeForeground}">
                    <Run Text="https://github.com/alchemyyy/VolumeTrayAppWPF"/>
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <TextBlock Text="{loc:Loc Settings_About_Updates_Header}"
                   Style="{StaticResource SubsectionHeaderStyle}"/>

        <settingsUtils:SettingsCard Title="{loc:Loc Settings_About_CheckForUpdates_Title}"
                                    Description="{loc:Loc Settings_About_CheckForUpdates_Description}">
            <settingsUtils:SettingsCard.Control>
                <CheckBox x:Name="CheckForUpdatesToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="CheckForUpdatesEnabled"
                          Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </settingsUtils:SettingsCard.Control>
        </settingsUtils:SettingsCard>

        <settingsUtils:SettingsCard Title="{loc:Loc Settings_About_ShowUpdateNotifications_Title}"
                                    Description="{loc:Loc Settings_About_ShowUpdateNotifications_Description}">
            <settingsUtils:SettingsCard.Control>
                <CheckBox x:Name="ShowUpdateNotificationsToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowUpdateNotificationsEnabled"
                          Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </settingsUtils:SettingsCard.Control>
        </settingsUtils:SettingsCard>

        <settingsUtils:SettingsCard Title="{loc:Loc Settings_About_ShowUpdateButton_Title}"
                                    Description="{loc:Loc Settings_About_ShowUpdateButton_Description}">
            <settingsUtils:SettingsCard.Control>
                <CheckBox x:Name="ShowUpdateButtonToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="ShowUpdateButtonInFlyout"
                          Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </settingsUtils:SettingsCard.Control>
        </settingsUtils:SettingsCard>

        <settingsUtils:SettingsCard Title="{loc:Loc Settings_About_UpdateInterval_Title}"
                                    Description="{loc:Loc Settings_About_UpdateInterval_Description}">
            <settingsUtils:SettingsCard.Control>
                <local:NumericSpinner x:Name="UpdateIntervalMinutesBox"
                                      Suffix="{loc:Loc Settings_About_UpdateInterval_MinutesSuffix}"
                                      Minimum="1"
                                      Maximum="1440"/>
            </settingsUtils:SettingsCard.Control>
        </settingsUtils:SettingsCard>

        <Border Style="{StaticResource SettingsCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Style="{StaticResource SettingsCardTitlePanel}">
                    <TextBlock Style="{StaticResource SettingTitleStyle}"
                               Text="{loc:Loc Settings_About_UpdateActions_Title}"/>
                    <TextBlock x:Name="UpdateStatusText"
                               Style="{StaticResource SettingDescriptionStyle}"
                               Text="..."/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="CheckForUpdatesButton"
                            Style="{StaticResource SettingsButtonStyle}"
                            Content="{loc:Loc Settings_About_CheckForUpdates_Button}"
                            Padding="14,6"
                            Margin="{StaticResource RightSpacerSmall}"
                            Click="CheckForUpdatesButton_Click"/>
                    <Button x:Name="InstallUpdateButton"
                            Style="{StaticResource SettingsButtonStyle}"
                            Content="{loc:Loc Settings_About_InstallUpdate_UpToDate}"
                            Padding="14,6"
                            IsEnabled="False"
                            Click="InstallUpdateButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
